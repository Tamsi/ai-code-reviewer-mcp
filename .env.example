# LLM provider selection: "vllm" | "ollama" | "openai"
LLM_PROVIDER=vllm

# OpenAI-compatible base URL of the model server.
#   - vLLM on AWS:  https://<ec2-host>:8000/v1
#   - Ollama local: http://localhost:11434/v1
#   - OpenAI:       https://api.openai.com/v1
QWEN_BASE_URL=https://your-aws-host:8000/v1

# API key for the model server (vLLM --api-key, or your OpenAI key).
QWEN_API_KEY=changeme

# HuggingFace checkpoint loaded on the vLLM server (--model).
LLM_MODEL=cyankiwi/Qwen3.6-27B-AWQ-INT4

# OpenAI API alias exposed by vLLM (--served-model-name). Use this id in API
# requests and in Cursor (e.g. gpt-4o-mini). Optional: defaults to LLM_MODEL.
LLM_SERVED_NAME=gpt-4o-mini

# Sampling controls (optional).
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=4096

# GitHub token (repo scope) used to read repositories, PRs and diffs.
# A classic or fine-grained PAT. Public repos work without it but get rate limited.
GITHUB_TOKEN=

# HuggingFace token, used only by the publishing scripts.
HF_TOKEN=
